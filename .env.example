# Stripe secret key for processing payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/vt_liquor_api

# Server port
PORT=3000

# Comma-separated list of valid API keys (one per retailer)
# Format: retailerId:apiKey,retailerId:apiKey
VALID_API_KEYS=retailer_001:key_abc123,retailer_002:key_def456
